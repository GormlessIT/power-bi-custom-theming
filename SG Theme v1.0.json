    },
    "largeLightLabel": 
    {
      "fontFace": "Roboto",
      "color": "#5e5e5e",
      "fontSize": 14,
      "fontWeight": "400"
    },
    "boldLabel": 
    {
      "fontFace": "Roboto",
      "color": "#1a1a1a",
      "fontSize": 16,
